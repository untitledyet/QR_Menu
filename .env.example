SECRET_KEY=your-secret-key-here
DATABASE_URL=sqlite:///menu.db
FLASK_DEBUG=1
LOG_TO_STDOUT=1

# SMTP (email verification)
SMTP_HOST=smtp.zoho.eu
SMTP_PORT=465
SMTP_USER=
SMTP_PASS=
SMTP_FROM=
BASE_URL=http://localhost:5001

# SMS (smsoffice.ge)
SMS_API_KEY=
SMS_SENDER=Tably

# Google Places
GOOGLE_PLACES_API_KEY=

# OpenAI (menu scraper AI analysis)
OPENAI_API_KEY=

# Cloudflare R2 (photo storage for scraped menu photos)
R2_ENDPOINT=https://<account_id>.r2.cloudflarestorage.com
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=tably-menu-photos
R2_PUBLIC_URL=https://pub-<hash>.r2.dev
